{
    "name": "body-is-diet-backend",
    "version": "1.0.0",
    "description": "REST API backend for Body is Diet app",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "jest --runInBand --forceExit"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testMatch": ["**/src/test/**/*.test.ts"],
        "moduleFileExtensions": ["ts", "js"],
        "collectCoverageFrom": [
            "src/**/*.ts",
            "!src/test/**",
            "!src/index.ts"
        ]
    },
    "dependencies": {
        "@databases/sqlite": "^4.0.1",
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.3",
        "jsonwebtoken": "^9.0.2",
        "nodemailer": "^6.9.13",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.12",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/node": "^20.11.30",
        "@types/nodemailer": "^6.4.14",
        "@types/supertest": "^6.0.2",
        "jest": "^29.7.0",
        "supertest": "^7.0.0",
        "ts-jest": "^29.1.4",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.3"
    }
}