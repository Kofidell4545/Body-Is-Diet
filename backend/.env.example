# Server
PORT=3000
NODE_ENV=development

# JWT Secrets (change these to long random strings in production)
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Database
DATABASE_URL="file:./dev.db"

# Email (Ethereal for dev — https://ethereal.email, SMTP for prod)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Body is Diet <noreply@bodyisdiet.com>"

# App (frontend URL for password reset links)
CLIENT_URL=exp://localhost:8081
